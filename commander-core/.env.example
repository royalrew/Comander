# ==========================================
# THE GENESIS PROFILE & SECURITY
# ==========================================
ENVIRONMENT=production
CEO_MODE=true
# Hårdkodad sökväg till mappen Commandern får röra (Byt ut mot din riktiga)
ALLOWED_MISSIONS_DIR=/absolute/path/to/projects/active-missions 
ACTIVE_PROJECT_DIR=/absolute/path/to/current/project

# ==========================================
# 🧠 HJÄRNAN & MUSKLERNA (LiteLLM / Routern)
# ==========================================
CORTEX_MODEL=gpt-4o
MUSCLE_CODER_MODEL=gpt-5.2
WATCHDOG_MODEL=ollama/llama3
OPENAI_API_KEY=sk-din-nyckel

# ==========================================
# 🗄️ MINNET (OpenSearch)
# ==========================================
OPENSEARCH_URL=https://din-railway-opensearch-url.up.railway.app
OPENSEARCH_USER=elastic
OPENSEARCH_PWD=ditt-lösenord
OPENSEARCH_INDEX_NAME=commander_core_memory 

# ==========================================
# 🗃️ STRUKTURERAD DATA (Postgres)
# ==========================================
DATABASE_URL=postgresql://postgres:lösenord@din-railway-db.up.railway.app:5432/commander_db

# ==========================================
# ☁️ TILLGÅNGAR (Cloudflare R2)
# ==========================================
CLOUDFLARE_R2_ACCESS_KEY=your-r2-key
CLOUDFLARE_R2_SECRET_KEY=your-r2-secret
CLOUDFLARE_R2_BUCKET_NAME=hype-engine-media

# ==========================================
# 📱 KOMMUNIKATION (Telegram)
# ==========================================
TELEGRAM_BOT_TOKEN=your-token
TELEGRAM_AUTHORIZED_USER_ID=123456789 

# ==========================================
# 💰 CFO MODULEN (Stripe & Ekonomi)
# ==========================================
STRIPE_SECRET_KEY=sk_live_your-key
MAX_DAILY_API_SPEND_USD=2.00

# ==========================================
# 🕷️ CLAWBOT (Advanced Scraping)
# ==========================================
BRIGHT_DATA_PROXY=http://brd-customer-xxxx-zone-xxxx:password@zproxy.lum-superproxy.io:22225
SCRAPINGBEE_API_KEY=optional_key_if_using_scrapingbee
